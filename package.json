{
  "name": "@hemaaanth/icons",
  "version": "0.1.1",
  "description": "Meaningful, framework-neutral microanimated icons.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "npm run generate && vite",
    "dev:builder": "npm run generate && vite --open /icons/builder.html",
    "generate": "tsx scripts/generate.ts",
    "build:lib": "npm run generate && tsup && node scripts/copy-static.mjs",
    "build:site": "npm run generate && vite build",
    "build": "npm run build:lib && npm run build:site",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "icon:new": "node scripts/new-icon.mjs",
    "icon:finalize": "node scripts/finalize-icon.mjs",
    "prepack": "npm run build:lib",
    "prepare": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=5.8.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "svelte": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dialkit": "^1.4.2",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "lucide-static": "^1.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "svelte": "^5.36.0",
    "tsx": "^4.20.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.1.5",
    "vitest": "^3.2.0",
    "vue": "^3.5.0"
  }
}
